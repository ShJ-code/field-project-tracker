# --- Server (packages/server) ---
# Port the Express API listens on
PORT=4000
# SQLite database file (created on first run; relative to packages/server)
DB_PATH=./data/field-tracker.db
# Base URL for the Open-Meteo weather API (the external "seam")
OPEN_METEO_BASE_URL=https://api.open-meteo.com
# Base URL for the Nominatim geocoding API (address -> coordinates)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Identifies this app to external APIs (weather + geocoding); some CDNs block
# the default runtime User-Agent, so set a descriptive one in production
APP_USER_AGENT=field-project-tracker/0.1 (+https://github.com/ShJ-code/field-project-tracker)
# Allowed CORS origin for the web app
WEB_ORIGIN=http://localhost:5173

# --- Web (packages/web) ---
# Base URL the web app uses to reach the API
VITE_API_BASE_URL=http://localhost:4000
