# --- Server (packages/server) ---
# Port the Express API listens on
PORT=4000
# SQLite database file (created on first run; relative to packages/server)
DB_PATH=./data/field-tracker.db
# Base URL for the Open-Meteo weather API (the external "seam")
OPEN_METEO_BASE_URL=https://api.open-meteo.com
# Allowed CORS origin for the web app
WEB_ORIGIN=http://localhost:5173

# --- Web (packages/web) ---
# Base URL the web app uses to reach the API
VITE_API_BASE_URL=http://localhost:4000
